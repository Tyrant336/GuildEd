# Person 3: Web Scraper / Bookshelf API — copy to .env and fill in values

# --- Search (set at least one for better results; else DuckDuckGo is used) ---
# Tavily (recommended): https://tavily.com
TAVILY_API_KEY=
# Exa: https://exa.ai
EXA_API_KEY=

# --- AWS Bedrock (scoring + summaries; optional, app works without) ---
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
# Or use a named profile instead of keys:
# AWS_PROFILE=your-profile

# Optional: override Bedrock model (default: Claude Haiku)
# BEDROCK_MODEL_ID=anthropic.claude-3-haiku-20240307-v1:0

# --- S3 cache (optional; bookshelf results cached to S3 when set) ---
S3_BUCKET=
# S3_PREFIX=bookshelf

# --- RAG memory (optional; set one for embeddings) ---
# OpenAI (preferred for embeddings): https://platform.openai.com
OPENAI_API_KEY=
# Or use AWS Bedrock Titan Embed (no extra key if AWS already set)
# BEDROCK_EMBED_MODEL_ID=amazon.titan-embed-text-v2:0
# Chroma DB persistence path (default: Person3/FastAPI/chroma_data)
# CHROMA_PERSIST_PATH=./chroma_data
